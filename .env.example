# Delta Exchange India credentials
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Risk parameters
MAX_EQUITY_DRAWDOWN_PCT=10.0      # Emergency close threshold (% of total equity)
RISK_PER_TRADE_PCT=1.0            # % of equity risked per trade
BRACKET_SLIPPAGE_TICKS=5         # stop-limit exit offset past trigger
CRYPTO_LEVERAGE=50                 # BTC, SOL, ETH, BNB leverage (max 100x)
COMMODITY_LEVERAGE=30              # XAUT leverage

# Strategy timeframe
CANDLE_TIMEFRAME=1m
VWAP_WINDOW=150                  # rolling tick window for VWAP + SD bands
VWAP_BAND_SD=1.75                # entry band multiplier (lower = more touches; try 1.5-2.0)
RSI_PERIOD=7
RSI_OVERSOLD=30                  # long threshold (lower = stricter)
RSI_OVERBOUGHT=70                # short threshold (higher = stricter)
WICK_RATIO=1.5                   # wick >= ratio × body (lower = more patterns; try 1.0-2.0)

# Outcome tracking
TRADES_CSV=trades.csv           # outcome log (paper + live)
SUMMARY_INTERVAL_SEC=300        # seconds between summary log lines
COOLDOWN_SEC=120                 # post-trade cooldown per symbol (lower = more opportunities)

# Operational
LOG_LEVEL=INFO                   # DEBUG = per-candle gate breakdown
DRY_RUN=true                      # true = log signals, skip order submission
